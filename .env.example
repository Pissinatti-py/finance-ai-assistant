# Single Postgres + pgvector database. The hostname "db" matches docker-compose;
# use localhost when running the app outside Docker.
DATABASE_URL=postgres://finance:finance@db:5432/finance

# Anthropic API key — the only cloud credential needed (get one at console.anthropic.com).
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Local embeddings (fastembed, CPU). EMBEDDING_DIM must match the model output.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# Shared secret clients send as the X-API-Key header to reach /chat and /ingest.
AI_API_KEY=change-me

CACHE_SIMILARITY_THRESHOLD=0.92
AGENT_MAX_ITERATIONS=5
MAX_CONTEXT_TOKENS=8000
LOG_LEVEL=INFO
